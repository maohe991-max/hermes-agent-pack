#!/usr/bin/env bash
#
# agent-squad — Hermes Agent Pack CLI
#
# 38+ pre-built sub-agent personas for Hermes Agent.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PACK_DIR="$(dirname "$SCRIPT_DIR")"

BOLD='\033[1m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

usage() {
  echo -e "${BOLD}agent-squad — Hermes Agent Pack v0.7.0${NC}"
  echo ""
  echo -e "${GREEN}Description:${NC}"
  echo "  38+ pre-built sub-agent personas for Hermes Agent."
  echo ""
  echo -e "${GREEN}Usage:${NC}"
  echo "  agent-squad [command]"
  echo ""
  echo -e "${GREEN}Commands:${NC}"
  echo -e "  ${CYAN}list${NC}        列出所有可用的 sub-agent 身份"
  echo -e "  ${CYAN}info <name>${NC} 显示指定 sub-agent 的详细信息"
  echo -e "  ${CYAN}install${NC}    安装 skills 到 Hermes Agent"
  echo -e "  ${CYAN}help${NC}       显示此帮助信息"
  echo ""
  echo -e "${GREEN}Examples:${NC}"
  echo "  agent-squad list"
  echo "  agent-squad info code-reviewer"
  echo "  agent-squad install"
  echo ""
}

list_agents() {
  local skills_dir="$PACK_DIR/skills"
  if [ ! -d "$skills_dir" ]; then
    echo -e "${YELLOW}未找到 skills/ 目录。${NC}"
    echo "请确保在 hermes-agent-pack 项目根目录下运行。"
    exit 1
  fi
  echo -e "${BOLD}可用的 sub-agent 身份:${NC}"
  echo ""
  for dir in "$skills_dir"/*/; do
    local name
    name="$(basename "$dir")"
    echo "  • $name"
  done
}

info_agent() {
  local name="$1"
  local skill_dir="$PACK_DIR/skills/$name"
  if [ ! -d "$skill_dir" ]; then
    echo -e "${YELLOW}未找到 sub-agent '$name'。${NC}"
    echo "使用 'agent-squad list' 查看所有可用身份。"
    exit 1
  fi
  echo -e "${BOLD}Sub-Agent: ${CYAN}$name${NC}"
  echo ""
  if [ -f "$skill_dir/README.md" ]; then
    cat "$skill_dir/README.md"
  else
    echo "（无额外说明）"
  fi
}

case "${1:-help}" in
  list)
    list_agents
    ;;
  info)
    if [ $# -lt 2 ]; then
      echo -e "${YELLOW}请指定 sub-agent 名称。${NC}"
      echo "用法: agent-squad info <name>"
      exit 1
    fi
    info_agent "$2"
    ;;
  install)
    echo "正在安装 skills 到 Hermes Agent..."
    node "$PACK_DIR/scripts/install.js"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo -e "${YELLOW}未知命令: $1${NC}"
    echo ""
    usage
    exit 1
    ;;
esac
